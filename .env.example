# PostgreSQL connection string (Supabase direct connection)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# WhatsApp webhook verification token — you choose this string
# Set the same value in Meta's developer dashboard under webhook configuration
WHATSAPP_VERIFY_TOKEN=your-random-verify-token-here

# Fernet encryption key for WhatsApp access tokens
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Google Gemini API key — from Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here

# Google Service Account JSON (full JSON string, one line)
# 1. Create a project in Google Cloud Console
# 2. Enable the Google Calendar API
# 3. Create a service account and download the JSON
# 4. Paste the entire JSON on one line here
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Admin API key for protecting admin endpoints (X-API-Key header)
ADMIN_API_KEY=your-secret-admin-key-here

# Environment — development | production
APP_ENV=development

# Log level — DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
